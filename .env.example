# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development

# ── turath.io ingestion ───────────────────────────────────────────────────────
# Public, no auth required. Be polite: keep the rate modest.
TURATH_API_BASE=https://api.turath.io
TURATH_FILES_BASE=https://files.turath.io
TURATH_RATE_PER_SEC=4
TURATH_MAX_RETRIES=4
TURATH_TIMEOUT=30
# Identify the bot honestly (good crawling etiquette).
TURATH_USER_AGENT=HadithResearchBot/0.1 (+https://github.com/a7medhosny92-cpu/hadith-research-backend)

# Where downloaded raw corpus + processed data live (kept out of git).
DATA_DIR=data

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://hadith:hadith@localhost:5432/hadith

# ── Embeddings (local, CPU-friendly default) ──────────────────────────────────
# Used for semantic search on the production (pgvector) backend. EMBEDDING_DIM must
# match the model's output dimension.
EMBEDDING_MODEL=Omartificial-Intelligence-Space/Arabic-Triplet-Matryoshka-V2
EMBEDDING_DIM=768

# ── Rijal (narrator gradings for /verify-isnad) ───────────────────────────────
# A curated seed ships in the package; point this at a fuller رجال JSONL to grade
# more narrators (see scripts/build_rijal.py). Leave unset to use the seed only.
# RIJAL_PATH=data/rijal.jsonl

# ── LLM engine (provider-agnostic via LiteLLM) ────────────────────────────────
# /ask has a "brain" switch you can flip per request (/ask?engine=local|remote|off)
# or default here with LLM_DEFAULT_ENGINE:
#   off    → cited, extractive answer; no LLM, runs anywhere (the default)
#   local  → Ollama on this machine (private, free, offline)
#   remote → a cloud model (Claude, …); fast/strong even on a laptop without a GPU
# Switching is config-only — no code changes.
LLM_DEFAULT_ENGINE=off
# The local brain. On a CPU-only laptop a smaller model is much faster, e.g.
# ollama/qwen2.5:3b — set this to whatever you've pulled with `ollama pull`.
LLM_LOCAL_MODEL=ollama/qwen2.5:7b
# The default remote brain — ANY LiteLLM model id (provider/model). You can also pick
# the model per request via /ask?model=… or in the desktop app's model box. Examples:
#   anthropic/claude-sonnet-4-6 · openai/gpt-4o · gemini/gemini-2.0-flash
#   groq/llama-3.3-70b-versatile · mistral/mistral-large-latest · ollama/llama3
LLM_REMOTE_MODEL=anthropic/claude-sonnet-4-6
LLM_TEMPERATURE=0.2
OLLAMA_API_BASE=http://localhost:11434
# Provider API keys — set the one(s) for the model(s) you use. Any *_API_KEY here is
# made available to the engine automatically (no code change to switch providers).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
